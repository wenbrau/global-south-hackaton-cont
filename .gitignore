# --- Secrets: never commit real keys ---
# Ignore every .env anywhere (root or any subdir), incl. variants like .env.local,
# but ALWAYS keep the *.env.example templates so others know which keys to set.
.env
.env.*
*.env
**/.env
**/.env.*
!.env.example
!*.env.example
!**/.env.example

# OS / editor cruft
.DS_Store

# Python
__pycache__/
*.pyc

# Virtual environments
.venv/
venv/
env/
ENV/
**/.venv/

# Claude Code local state
/.claude

# Notes on what to do next
notes_w

# --- Other secrets / credential-bearing files ---
# Keys, certs, keystores
*.pem
*.key
*.p12
*.pfx
*.crt
*.cer
*.der
*.keystore
*.jks
id_rsa
id_dsa
id_ecdsa
id_ed25519
# Cloud / service-account credentials
*credentials*.json
*service-account*.json
*service_account*.json
gcp-*.json
aws-credentials
.aws/
# Package-manager / tooling auth
.npmrc
.pypirc
.netrc
# Generic secret files
secrets.*
*secret*.yaml
*secret*.yml
*.secrets
